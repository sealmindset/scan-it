# scan-it AI Validation Configuration
# Copy to .env and fill in your values: cp .env.example .env
# Only needed when using --ai-validate flag

# Provider selection: anthropic_foundry (default), anthropic, claude
AI_PROVIDER=anthropic_foundry

# Azure AI Foundry (default provider)
ANTHROPIC_FOUNDRY_API_KEY=your-api-key-here
ANTHROPIC_FOUNDRY_BASE_URL=https://your-instance.services.ai.azure.com/anthropic
ANTHROPIC_DEFAULT_SONNET_MODEL=cogdep-aifoundry-dev-eus2-claude-sonnet-4-5

# Anthropic Direct (alternative provider)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
